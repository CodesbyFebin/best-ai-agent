{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/server.js",
          "dist/server.js.map",
          "dist/route-meta.json",
          "dist/contentIndex.json",
          "dist/content-index.json",
          "dist/llms.txt",
          "dist/llms-full.txt",
          "dist/client/**",
          "public/assets/**",
          "public/sitemap.xml",
          "public/ai-agent-sitemap.xml",
          "public/tool-sitemap.xml",
          "public/comparison-sitemap.xml",
          "public/pricing-sitemap.xml",
          "public/alternatives-sitemap.xml",
          "public/tutorials-sitemap.xml",
          "public/glossary-sitemap.xml",
          "public/mcp-sitemap.xml",
          "public/author-sitemap.xml",
          "public/hub-sitemap.xml",
          "public/calculators-sitemap.xml",
          "public/image-sitemap.xml",
          "public/feed.xml",
          "public/llms.txt",
          "public/robots.txt",
          "public/favicon.ico",
          "public/site.webmanifest",
          "public/contentIndex.json",
          "public/content-index.json",
          "public/entity-index.json",
          "public/knowledge-graph.json",
          "public/tool-relationships.json",
          "public/route-meta.json",
          "public/indexnow-key.txt",
          "public/7f4f2d728f93411eb9a03bestaiagentin.txt"
        ]
      }
    },
    {
      "src": "public/assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "server.ts" }
  ]
}