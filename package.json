{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "generate:seo": "node scripts/generate_sitemaps.js",
    "build": "node scripts/generate_sitemaps.js && vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "node dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "expand": "node scripts/expand_content.js",
    "validate:content": "node scripts/validate_content.js",
    "validate:jsonld": "node scripts/validate_jsonld.js",
    "validate:slugs": "tsx scripts/validate_slugs.ts",
    "validate:links": "node scripts/validate_links.js",
    "validate:canonicals": "node scripts/validate_canonicals.js",
    "validate:assets": "node scripts/validate_assets.js",
    "validate:sitemaps": "node scripts/validate_sitemaps.js",
    "check:words": "node scripts/check_word_counts.js",
    "submit:indexnow": "node scripts/submit_indexnow.js",
    "seo:audit": "npm run generate:seo && npm run validate:slugs && npm run validate:assets && npm run validate:content && npm run validate:jsonld && npm run validate:links && npm run validate:canonicals && npm run validate:sitemaps && npm run check:words"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
